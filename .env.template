# ============================================================
# AlgoBot — Environment Variables Template
# Copy this file to .env and fill in your real values
# NEVER commit .env to Git
# ============================================================

# ── Database ─────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SQLITE_PATH=data/algobot.db

# ── Market Data APIs ─────────────────────────────────────────
# Finnhub (free): https://finnhub.io
FINNHUB_API_KEY=YOUR_FINNHUB_KEY

# Binance (for crypto data only — no trading):
# Public data endpoints work without API keys.
# Add keys here if you need private endpoints later.
BINANCE_API_KEY=
BINANCE_SECRET=

# ── AI ───────────────────────────────────────────────────────
# LM Studio — runs on your local machine, no key needed
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=llama-3.1-8b-instruct

# OpenRouter — Kimi K2 fallback (optional, ~$3-5/mo)
# https://openrouter.ai
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY
OPENROUTER_MODEL=moonshotai/kimi-k2

# ── Broker — FP Markets (MT5) ────────────────────────────────
# Leave blank until Phase 7 (paper trading)
FP_MARKETS_LOGIN=
FP_MARKETS_PASSWORD=
FP_MARKETS_SERVER=FPMarkets-Demo

# ── Trading mode & multi-broker ───────────────────────────────
# paper = permissive routing (Alpaca paper + IBKR paper); live = strict routing rules
TRADING_MODE=paper
ALPACA_API_KEY=YOUR_ALPACA_API_KEY
ALPACA_SECRET_KEY=YOUR_ALPACA_SECRET_KEY
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
ALPACA_ENABLED=true
KRAKEN_API_KEY=
KRAKEN_SECRET=
KRAKEN_ENABLED=true
FXCM_API_KEY=
FXCM_ACCESS_TOKEN=
FXCM_ACCOUNT_TYPE=demo
FXCM_ENABLED=false
IBKR_ENABLED=true

# ── Interactive Brokers (IBKR) ───────────────────────────────
# Connection settings for IBKR TWS or Gateway
IBKR_HOST=127.0.0.1
IBKR_PORT=7497                          # 7497 for TWS paper, 7496 for TWS live, 4002 for Gateway paper, 4001 for Gateway live
IBKR_CLIENT_ID=1                        # Execution adapter uses this + 1 for ib_insync
IBKR_DATA_CLIENT_ID=2                   # Client ID for market data (different from execution adapter)

# Rotating Scanner Configuration
IBKR_BATCH_SIZE=30                      # Number of symbols per batch (20-50)
IBKR_ROTATION_DELAY_SECONDS=10          # Delay between batches (5-30 seconds)
IBKR_ROTATION_CYCLE_MINUTES=10          # Target time for full rotation (5-15 minutes)

# Live Streaming Configuration
IBKR_MAX_LIVE_SUBSCRIPTIONS=80          # Max concurrent live subscriptions (stay under 100 limit)

# Historical Data Configuration
IBKR_HISTORICAL_CANDLE_COUNT=200        # Number of candles to fetch per request (50-200)

# Cache Configuration
IBKR_CACHE_RETENTION_HOURS=24           # How long to keep cached data (hours)
IBKR_CACHE_PERSIST_PATH=data/historical # Directory for cache persistence

# Rate Limiting Configuration
IBKR_RATE_LIMIT_REQUESTS_PER_10MIN=60   # Max requests per 10-minute window
IBKR_MIN_REQUEST_DELAY_SECONDS=1.0      # Minimum delay between requests (seconds)

# Reconnection Configuration
IBKR_RECONNECT_MAX_ATTEMPTS=5           # Max reconnection attempts before degraded mode
IBKR_RECONNECT_BACKOFF_BASE=2.0         # Exponential backoff base for reconnection

# ── Notifications ────────────────────────────────────────────
# Pushover (one-time $5): https://pushover.net
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=

# ── Risk Parameters ──────────────────────────────────────────
# These values match your confirmed rules exactly
ACCOUNT_BALANCE=10000
MAX_RISK_PER_TRADE=0.01        # 1% per trade
STOP_LOSS_PCT=0.02             # 2% hard stop
MAX_DAILY_DRAWDOWN=0.10        # 10% kill switch
MAX_TRADES_PER_HOUR=15         # hard cap

# ── Trailing take-profit (peak giveback) ─────────────────────
# Exit when price gives back this fraction of max favorable move from entry (e.g. 0.35 = 35%)
TRAILING_TP_ENABLED=true
TRAILING_TP_GIVEBACK=0.35

# ── ML Thresholds ────────────────────────────────────────────
ML_CONFIDENCE_THRESHOLD=0.60   # below this = signal suppressed
AI_CONFIDENCE_THRESHOLD=0.60   # below this = signal flagged

# ── Timezone ─────────────────────────────────────────────────
TIMEZONE=America/Toronto

# ── Paths ────────────────────────────────────────────────────
LOG_DIR=logs
DATA_DIR=data
MODELS_DIR=models
